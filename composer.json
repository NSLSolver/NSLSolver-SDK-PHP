{
    "name": "nslsolver/nslsolver",
    "description": "Official PHP SDK for the NSLSolver captcha solving API",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "captcha",
        "turnstile",
        "cloudflare",
        "kasada",
        "solver",
        "nslsolver"
    ],
    "authors": [
        {
            "name": "NSLSolver",
            "email": "support@nslsolver.com"
        }
    ],
    "require": {
        "php": ">=8.1",
        "guzzlehttp/guzzle": "^7.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0"
    },
    "autoload": {
        "psr-4": {
            "NSLSolver\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "NSLSolver\\Tests\\": "tests/"
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "config": {
        "sort-packages": true
    }
}
